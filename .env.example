# Database
DATABASE_URL_MASTER=postgresql://postgres:postgres@localhost:5432/viz_ai_master
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GITHUB_OAUTH_CLIENT_ID=your_github_client_id_here
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_this_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
MASTER_ENCRYPTION_KEY=your_master_encryption_key_32_chars_min

# App Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3000
AI_LAYER_URL=http://localhost:8000
WS_URL=ws://localhost:3000

# Region
REGION=Asia
TIMEZONE=Asia/Kolkata

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Email & SMS (placeholder, implement later)
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Voice APIs
ELEVENLABS_API_KEY=your_elevenlabs_key
WHISPER_API_KEY=your_openai_key_for_whisper

# Logging
LOG_LEVEL=debug
